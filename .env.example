# ===== Receipt Tax Bot configuration =====
# setup.bat fills this in for you. To do it by hand: copy this file to ".env"
# and replace the placeholder below with the token @BotFather gave you.
TELEGRAM_BOT_TOKEN=PASTE_YOUR_TOKEN_HERE

# Who may use the bot. EMPTY = open to everyone (each user gets their own
# private storage). Or list numeric Telegram IDs (get yours by messaging
# @userinfobot), comma-separated, to restrict it to specific people.
ALLOWED_USER_IDS=

# --- Advanced (leave empty for normal PC use) ---

# Secret key for the /backup HTTP endpoint, only needed for cloud hosting
# with PC sync. Empty = endpoint disabled.
BACKUP_KEY=

# Public URL of your cloud deployment, used by sync_from_cloud.ps1.
CLOUD_URL=

# Only needed if Tesseract is installed somewhere unusual.
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
